{
  "name": "webstore-vuepress",
  "version": "3.0.0",
  "description": "WebStore 网页商店平台 V3.0 - 网页版 App Store",
  "type": "module",
  "scripts": {
    "dev": "vuepress dev docs",
    "prebuild:css": "node -e \"const fs=require('fs'),p=require('path');const d='node_modules/@vuepress/plugin-git/dist';try{['GitChangelog-Do7jXfkp.css','GitContributors-BiR-YbYa.css'].forEach(f=>{if(!fs.existsSync(p.join(d,f)))fs.writeFileSync(p.join(d,f),'')})}catch(e){}\"",
    "build": "npm run prebuild:css && node --experimental-loader ./css-load-hook.mjs node_modules/vuepress/bin/vuepress.js build docs",
    "clean-dev": "vuepress dev docs --clean-cache"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vuepress": "^2.0.0-rc.9",
    "@vuepress/bundler-vite": "^2.0.0-rc.9",
    "@vuepress/theme-default": "^2.0.0-rc.9"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "sass-embedded": "^1.71.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
